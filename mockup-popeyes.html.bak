<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>C Pizza — Pizzeria Artisanale à Maképé Saint Tropez, Douala</title>
  <meta name="description" content="C Pizza, la pizzeria artisanale de Maképé Saint Tropez à Douala. Four à 450°C, pâte fermentée 72h, livraison 30 min. Commandez maintenant.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,300;1,400&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet">

  <style>
    /* ─── TOKENS ─── */
    :root {
      --red:        #AD0004;
      --red-hover:  #8C0003;
      --yellow:     #F3EC22;
      --yellow-dim: rgba(243,236,34,0.15);
      --gray:       #494949;
      --gray-light: #5a5a5a;
      --black:      #494949;
      --black-deep: #3a3a3a;
      --cream:      #FAFAF5;
      --white:      #FFFFFF;
      --text-light: #F5F0E8;
      --text-muted: #B0A09A;

      --font-display: 'Bebas Neue', sans-serif;
      --font-script:  'Playfair Display', serif;
      --font-body:    'Montserrat', sans-serif;

      --radius-btn: 50px;
      --radius-card: 14px;
      --shadow-card: 0 6px 28px rgba(0,0,0,0.10);
      --shadow-card-hover: 0 14px 40px rgba(173,0,4,0.18), 0 4px 12px rgba(0,0,0,0.12);

      --ease: cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* ─── RESET ─── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--font-body);
      background: var(--black);
      color: var(--text-light);
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }
    img { max-width: 100%; display: block; }
    a { text-decoration: none; color: inherit; }
    button { cursor: pointer; font-family: var(--font-body); border: none; }

    /* ─── FADE-UP ANIMATION ─── */
    .fade-up {
      opacity: 0;
      transform: translateY(32px);
      transition: opacity 0.72s var(--ease), transform 0.72s var(--ease);
    }
    .fade-up.visible { opacity: 1; transform: translateY(0); }
    .fade-up.delay-1 { transition-delay: 0.1s; }
    .fade-up.delay-2 { transition-delay: 0.2s; }
    .fade-up.delay-3 { transition-delay: 0.3s; }
    .fade-up.delay-4 { transition-delay: 0.4s; }

    /* ─── SECTION LABEL ─── */
    .section-label {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-family: var(--font-body);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--yellow);
      margin-bottom: 16px;
    }
    .section-label::before {
      content: '';
      width: 28px;
      height: 2px;
      background: var(--yellow);
    }

    /* ─── BUTTONS ─── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 15px 34px;
      border-radius: var(--radius-btn);
      font-family: var(--font-body);
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      transition: transform 0.28s var(--ease), box-shadow 0.28s var(--ease), background 0.22s ease;
    }
    .btn:hover { transform: translateY(-2px); }
    .btn:active { transform: translateY(0); }
    .btn-red {
      background: var(--red);
      color: var(--white);
      box-shadow: 0 4px 18px rgba(173,0,4,0.35);
    }
    .btn-red:hover {
      background: var(--red-hover);
      box-shadow: 0 8px 30px rgba(173,0,4,0.50);
    }
    .btn-outline-yellow {
      background: transparent;
      color: var(--yellow);
      border: 2px solid var(--yellow);
    }
    .btn-outline-yellow:hover {
      background: var(--yellow-dim);
      box-shadow: 0 4px 20px rgba(243,236,34,0.18);
    }
    .btn-outline-white {
      background: transparent;
      color: var(--white);
      border: 2px solid rgba(255,255,255,0.5);
    }
    .btn-outline-white:hover {
      border-color: var(--white);
      background: rgba(255,255,255,0.06);
    }

    /* ════════════════════════════════════
       1. NAVIGATION
    ════════════════════════════════════ */
    #main-nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      background: var(--black);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      transition: background 0.3s ease, box-shadow 0.3s ease;
    }
    #main-nav.scrolled {
      background: rgba(16,0,0,0.96);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      box-shadow: 0 2px 24px rgba(0,0,0,0.4);
    }
    .nav-inner {
      max-width: 1320px;
      margin: 0 auto;
      padding: 0 32px;
      height: 72px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
    }
    .nav-logo {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-shrink: 0;
    }
    .nav-logo img {
      height: 46px;
      width: 46px;
      object-fit: contain;
      border-radius: 50%;
    }
    .nav-logo-text {
      font-family: var(--font-display);
      font-size: 1.5rem;
      letter-spacing: 0.05em;
      color: var(--white);
      line-height: 1;
    }
    .nav-logo-sub {
      font-family: var(--font-body);
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--yellow);
      margin-top: 2px;
    }
    .nav-links {
      display: flex;
      align-items: center;
      gap: 36px;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(245,240,232,0.75);
      position: relative;
      padding-bottom: 4px;
      transition: color 0.2s ease;
    }
    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0;
      width: 0; height: 2px;
      background: var(--yellow);
      transition: width 0.28s var(--ease);
    }
    .nav-links a:hover { color: var(--white); }
    .nav-links a:hover::after,
    .nav-links a.active::after { width: 100%; }
    .nav-links a.active { color: var(--white); }
    .nav-cta { flex-shrink: 0; }
    .nav-burger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      padding: 6px;
    }
    .nav-burger span {
      display: block;
      width: 24px;
      height: 2px;
      background: var(--white);
      transition: transform 0.3s ease, opacity 0.3s ease;
    }

    /* Mobile drawer */
    .mobile-menu {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 99;
      background: var(--black);
      padding: 100px 32px 40px;
      flex-direction: column;
      gap: 32px;
    }
    .mobile-menu.open { display: flex; }
    .mobile-menu a {
      font-family: var(--font-display);
      font-size: 2.8rem;
      color: var(--white);
      letter-spacing: 0.06em;
      border-bottom: 1px solid rgba(255,255,255,0.08);
      padding-bottom: 20px;
    }
    .mobile-menu a:hover { color: var(--yellow); }

    /* ════════════════════════════════════
       2. HERO
    ════════════════════════════════════ */
    #hero {
      min-height: 100vh;
      position: relative;
      display: flex;
      align-items: center;
      overflow: hidden;
      background: var(--black);
    }
    .hero-bg {
      position: absolute;
      inset: 0;
      background-image: url('https://placehold.co/1600x900/1a0000/330000?text=.');
      background-size: cover;
      background-position: center;
    }
    .hero-bg img {
      width: 100%; height: 100%;
      object-fit: cover;
      opacity: 0.55;
    }
    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        135deg,
        rgba(16,0,0,0.92) 0%,
        rgba(16,0,0,0.65) 50%,
        rgba(16,0,0,0.40) 100%
      );
    }
    /* Yellow accent bar left */
    .hero-accent-bar {
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 5px;
      background: var(--yellow);
    }
    .hero-content {
      position: relative;
      z-index: 2;
      max-width: 1320px;
      margin: 0 auto;
      padding: 120px 32px 80px;
      width: 100%;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--yellow);
      color: var(--black);
      font-family: var(--font-body);
      font-size: 0.7rem;
      font-weight: 800;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      padding: 7px 16px;
      border-radius: 4px;
      margin-bottom: 24px;
    }
    .hero-badge svg { width: 12px; height: 12px; fill: var(--black); }
    .hero-title {
      font-family: var(--font-display);
      font-size: clamp(4rem, 10vw, 9.5rem);
      line-height: 0.92;
      letter-spacing: 0.02em;
      color: var(--white);
      margin-bottom: 28px;
      max-width: 900px;
    }
    .hero-title span { color: var(--yellow); }
    .hero-sub {
      font-family: var(--font-body);
      font-size: clamp(0.9rem, 1.4vw, 1.1rem);
      font-weight: 300;
      letter-spacing: 0.06em;
      color: rgba(245,240,232,0.80);
      margin-bottom: 44px;
      max-width: 500px;
      line-height: 1.8;
    }
    .hero-sub strong {
      font-weight: 700;
      color: var(--white);
    }
    .hero-ctas {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      align-items: center;
    }
    .hero-delivery-badge {
      position: absolute;
      right: 80px;
      bottom: 80px;
      width: 120px;
      height: 120px;
      border-radius: 50%;
      background: var(--red);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 16px;
      box-shadow: 0 8px 30px rgba(173,0,4,0.50);
      animation: pulse-badge 2.5s ease-in-out infinite;
    }
    .hero-delivery-badge .bd-num {
      font-family: var(--font-display);
      font-size: 2rem;
      color: var(--white);
      line-height: 1;
    }
    .hero-delivery-badge .bd-label {
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.85);
      line-height: 1.3;
    }
    @keyframes pulse-badge {
      0%, 100% { transform: scale(1); box-shadow: 0 8px 30px rgba(173,0,4,0.50); }
      50% { transform: scale(1.05); box-shadow: 0 12px 40px rgba(173,0,4,0.70); }
    }
    .hero-scroll-cue {
      position: absolute;
      bottom: 32px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      z-index: 2;
    }
    .hero-scroll-cue span {
      font-size: 0.62rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(245,240,232,0.45);
    }
    .hero-scroll-cue svg {
      width: 20px;
      animation: bounce-down 1.8s ease-in-out infinite;
    }
    @keyframes bounce-down {
      0%, 100% { transform: translateY(0); opacity: 0.5; }
      50% { transform: translateY(6px); opacity: 1; }
    }

    /* ════════════════════════════════════
       3. TRUST STRIP
    ════════════════════════════════════ */
    #trust-strip {
      background: var(--red);
      padding: 0;
      overflow: hidden;
    }
    .trust-inner {
      max-width: 1320px;
      margin: 0 auto;
      padding: 22px 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0;
    }
    .trust-item {
      display: flex;
      align-items: center;
      gap: 10px;
      flex: 1;
      justify-content: center;
    }
    .trust-item + .trust-item {
      border-left: 1px solid rgba(243,236,34,0.4);
    }
    .trust-icon {
      font-size: 1.4rem;
      line-height: 1;
    }
    .trust-num {
      font-family: var(--font-display);
      font-size: 1.85rem;
      color: var(--yellow);
      line-height: 1;
    }
    .trust-label {
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.9);
      line-height: 1.4;
    }

    /* ════════════════════════════════════
       3.5 QUICK LINKS (3 cards)
    ════════════════════════════════════ */
    #quick-links {
      background: var(--black);
      padding: 110px 32px 100px;
      position: relative;
    }
    .ql-inner {
      max-width: 1320px;
      margin: 0 auto;
    }
    .ql-header {
      text-align: center;
      margin-bottom: 64px;
    }
    .ql-header .section-label {
      justify-content: center;
    }
    .ql-header .section-label::before,
    .ql-header .section-label::after {
      content: '';
      width: 28px;
      height: 2px;
      background: var(--yellow);
    }
    .ql-title {
      font-family: var(--font-display);
      font-size: clamp(2.4rem, 5vw, 4rem);
      letter-spacing: 0.02em;
      color: var(--cream);
      line-height: 1;
    }
    .ql-title span { color: var(--yellow); }
    .ql-sub {
      font-size: 1rem;
      color: var(--text-muted);
      margin-top: 14px;
      max-width: 540px;
      margin-left: auto;
      margin-right: auto;
    }

    .ql-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 28px;
    }

    .ql-card {
      position: relative;
      background: var(--black-deep);
      border: 1px solid rgba(243,236,34,0.1);
      border-radius: var(--radius-card);
      padding: 48px 36px 40px;
      text-align: left;
      overflow: hidden;
      transition: transform 0.4s var(--ease), border-color 0.3s ease, box-shadow 0.4s var(--ease);
      display: block;
      color: inherit;
    }
    .ql-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, transparent 0%, rgba(173,0,4,0.10) 100%);
      opacity: 0;
      transition: opacity 0.4s var(--ease);
      pointer-events: none;
    }
    .ql-card:hover,
    .ql-card:focus-visible {
      transform: translateY(-8px);
      border-color: var(--yellow);
      box-shadow: 0 20px 50px rgba(173,0,4,0.22), 0 4px 12px rgba(0,0,0,0.3);
      outline: none;
    }
    .ql-card:hover::before,
    .ql-card:focus-visible::before { opacity: 1; }

    .ql-icon {
      width: 72px;
      height: 72px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--red);
      border-radius: 18px;
      margin-bottom: 32px;
      position: relative;
      z-index: 1;
      transition: background 0.3s ease, transform 0.4s var(--ease);
    }
    .ql-card:hover .ql-icon {
      background: var(--yellow);
      transform: rotate(-4deg) scale(1.05);
    }
    .ql-icon svg {
      width: 36px;
      height: 36px;
      stroke: var(--yellow);
      fill: none;
      stroke-width: 1.8;
      stroke-linecap: round;
      stroke-linejoin: round;
      transition: stroke 0.3s ease;
    }
    .ql-card:hover .ql-icon svg { stroke: var(--black); }

    .ql-card h3 {
      font-family: var(--font-display);
      font-size: 1.8rem;
      letter-spacing: 0.04em;
      color: var(--cream);
      margin-bottom: 12px;
      position: relative;
      z-index: 1;
    }
    .ql-card p {
      font-size: 0.94rem;
      color: var(--text-muted);
      line-height: 1.65;
      margin-bottom: 28px;
      position: relative;
      z-index: 1;
    }
    .ql-arrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--yellow);
      position: relative;
      z-index: 1;
      transition: gap 0.3s var(--ease);
    }
    .ql-card:hover .ql-arrow { gap: 14px; }
    .ql-arrow svg {
      width: 16px;
      height: 16px;
      stroke: var(--yellow);
      fill: none;
      stroke-width: 2.2;
      stroke-linecap: round;
      stroke-linejoin: round;
      transition: transform 0.3s var(--ease);
    }
    .ql-card:hover .ql-arrow svg { transform: translateX(4px); }

    @media (max-width: 900px) {
      .ql-grid { grid-template-columns: 1fr; gap: 18px; }
      #quick-links { padding: 70px 22px; }
      .ql-card { padding: 36px 28px; }
      .ql-header { margin-bottom: 44px; }
    }

    /* ════════════════════════════════════
       4. MENU SECTION
    ════════════════════════════════════ */
    #menu {
      background: var(--cream);
      padding: 100px 32px;
    }
    .menu-inner {
      max-width: 1320px;
      margin: 0 auto;
    }
    .menu-header {
      margin-bottom: 52px;
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 24px;
    }
    .menu-title {
      font-family: var(--font-display);
      font-size: clamp(2.8rem, 5vw, 5.5rem);
      color: var(--black);
      line-height: 0.95;
      letter-spacing: 0.02em;
    }
    .menu-title span { color: var(--red); }
    /* Tabs */
    .menu-tabs {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }
    .tab-btn {
      padding: 10px 24px;
      border-radius: 50px;
      font-family: var(--font-body);
      font-size: 0.76rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      background: transparent;
      color: var(--gray);
      border: 2px solid rgba(73,73,73,0.25);
      transition: background 0.22s ease, color 0.22s ease, border-color 0.22s ease, transform 0.22s ease;
    }
    .tab-btn:hover { border-color: var(--red); color: var(--red); }
    .tab-btn.active {
      background: var(--red);
      color: var(--white);
      border-color: var(--red);
      box-shadow: 0 4px 16px rgba(173,0,4,0.30);
    }
    .tab-btn.active:hover { transform: none; }

    /* Pizza grid */
    .pizza-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 28px;
    }
    .pizza-card {
      background: var(--white);
      border-radius: var(--radius-card);
      overflow: hidden;
      box-shadow: var(--shadow-card);
      transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease);
      cursor: pointer;
      display: none;
    }
    .pizza-card.show { display: block; }
    .pizza-card:hover {
      transform: translateY(-6px);
      box-shadow: var(--shadow-card-hover);
    }
    .pizza-card-img {
      position: relative;
      overflow: hidden;
      aspect-ratio: 4/3;
    }
    .pizza-card-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s var(--ease);
    }
    .pizza-card:hover .pizza-card-img img {
      transform: scale(1.06);
    }
    .pizza-badge {
      position: absolute;
      top: 14px;
      right: 14px;
      background: var(--yellow);
      color: var(--black);
      font-size: 0.62rem;
      font-weight: 800;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 5px 11px;
      border-radius: 50px;
    }
    .pizza-card-body {
      padding: 20px 24px 24px;
    }
    .pizza-name {
      font-family: var(--font-display);
      font-size: 1.5rem;
      color: var(--black);
      letter-spacing: 0.04em;
      margin-bottom: 6px;
    }
    .pizza-desc {
      font-size: 0.78rem;
      font-weight: 400;
      color: var(--gray);
      line-height: 1.7;
      margin-bottom: 18px;
    }
    .pizza-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .pizza-price {
      font-family: var(--font-body);
      font-size: 1.35rem;
      font-weight: 800;
      color: var(--red);
    }
    .pizza-price .price-small {
      font-size: 0.72rem;
      font-weight: 500;
      color: var(--gray);
      margin-left: 4px;
    }
    .btn-card {
      padding: 10px 22px;
      border-radius: 50px;
      font-family: var(--font-body);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      background: var(--red);
      color: var(--white);
      transition: background 0.22s ease, transform 0.22s ease, box-shadow 0.22s ease;
    }
    .btn-card:hover {
      background: var(--red-hover);
      transform: translateY(-1px);
      box-shadow: 0 4px 16px rgba(173,0,4,0.35);
    }

    /* ════════════════════════════════════
       5. OFFRES SECTION
    ════════════════════════════════════ */
    #offres {
      background: var(--black);
      padding: 100px 32px;
    }
    .offres-inner {
      max-width: 1320px;
      margin: 0 auto;
    }
    .offres-title {
      font-family: var(--font-display);
      font-size: clamp(2.8rem, 5vw, 5rem);
      color: var(--white);
      line-height: 0.95;
      margin-bottom: 52px;
      letter-spacing: 0.02em;
    }
    .offres-title span { color: var(--yellow); }
    .offres-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }
    .offre-card {
      position: relative;
      border-radius: var(--radius-card);
      overflow: hidden;
      background: #1A0505;
      display: flex;
      min-height: 260px;
      border: 1px solid rgba(173,0,4,0.2);
      transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease);
    }
    .offre-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 16px 40px rgba(173,0,4,0.25);
    }
    .offre-img {
      width: 42%;
      flex-shrink: 0;
      position: relative;
      overflow: hidden;
    }
    .offre-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s var(--ease);
    }
    .offre-card:hover .offre-img img { transform: scale(1.07); }
    .offre-body {
      padding: 28px 28px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 10px;
      position: relative;
      z-index: 1;
    }
    .offre-badge {
      display: inline-block;
      background: var(--yellow);
      color: var(--black);
      font-size: 0.62rem;
      font-weight: 800;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      padding: 5px 12px;
      border-radius: 50px;
      align-self: flex-start;
    }
    .offre-name {
      font-family: var(--font-display);
      font-size: 1.7rem;
      color: var(--white);
      letter-spacing: 0.04em;
      line-height: 1.1;
    }
    .offre-desc {
      font-size: 0.78rem;
      font-weight: 400;
      color: var(--text-muted);
      line-height: 1.7;
    }
    .offre-price-row {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-top: 4px;
    }
    .offre-price-old {
      font-size: 0.9rem;
      font-weight: 500;
      color: var(--text-muted);
      text-decoration: line-through;
    }
    .offre-price-new {
      font-family: var(--font-body);
      font-size: 1.4rem;
      font-weight: 800;
      color: var(--yellow);
    }

    /* Yellow accent line top */
    .offre-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: var(--yellow);
      opacity: 0;
      transition: opacity 0.3s ease;
    }
    .offre-card:hover::before { opacity: 1; }

    /* ════════════════════════════════════
       6. STORY SECTION
    ════════════════════════════════════ */
    #story {
      background: var(--cream);
      padding: 100px 32px;
    }
    .story-inner {
      max-width: 1320px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
    }
    .story-title {
      font-family: var(--font-display);
      font-size: clamp(2.6rem, 4.5vw, 5rem);
      color: var(--black);
      line-height: 0.95;
      letter-spacing: 0.02em;
      margin-bottom: 28px;
    }
    .story-title span { color: var(--red); }
    .story-text {
      font-size: 0.9rem;
      font-weight: 400;
      color: var(--gray);
      line-height: 1.85;
      margin-bottom: 40px;
    }
    .story-args {
      display: flex;
      flex-direction: column;
      gap: 18px;
    }
    .story-arg {
      display: flex;
      align-items: flex-start;
      gap: 16px;
    }
    .arg-icon {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      background: var(--red);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.3rem;
      flex-shrink: 0;
      box-shadow: 0 4px 16px rgba(173,0,4,0.30);
    }
    .arg-text { flex: 1; }
    .arg-title {
      font-family: var(--font-body);
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--black);
      margin-bottom: 3px;
      letter-spacing: 0.04em;
    }
    .arg-desc {
      font-size: 0.78rem;
      color: var(--gray);
      line-height: 1.65;
    }
    .story-img {
      position: relative;
    }
    .story-img-main {
      width: 100%;
      aspect-ratio: 4/5;
      object-fit: cover;
      border-radius: 20px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.18);
    }
    .story-img-float {
      position: absolute;
      bottom: -24px;
      left: -24px;
      width: 48%;
      aspect-ratio: 1;
      object-fit: cover;
      border-radius: 16px;
      border: 5px solid var(--cream);
      box-shadow: 0 10px 30px rgba(0,0,0,0.14);
    }
    .story-img-badge {
      position: absolute;
      top: 20px;
      right: -20px;
      background: var(--yellow);
      color: var(--black);
      font-family: var(--font-display);
      font-size: 1.8rem;
      padding: 16px 18px;
      border-radius: 14px;
      text-align: center;
      line-height: 1.1;
      box-shadow: 0 6px 20px rgba(243,236,34,0.40);
    }
    .story-img-badge .badge-sub {
      font-family: var(--font-body);
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      display: block;
    }

    /* ════════════════════════════════════
       7. TESTIMONIALS
    ════════════════════════════════════ */
    #avis {
      background: var(--white);
      padding: 100px 32px;
    }
    .avis-inner {
      max-width: 1320px;
      margin: 0 auto;
    }
    .avis-header {
      text-align: center;
      margin-bottom: 60px;
    }
    .avis-title {
      font-family: var(--font-display);
      font-size: clamp(2.5rem, 4vw, 4.5rem);
      color: var(--black);
      letter-spacing: 0.02em;
      margin-bottom: 12px;
    }
    .avis-sub {
      font-size: 0.88rem;
      color: var(--gray);
      font-weight: 400;
    }
    .avis-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
    .avis-card {
      background: var(--cream);
      border-radius: var(--radius-card);
      padding: 32px 28px;
      position: relative;
      transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease);
    }
    .avis-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 12px 36px rgba(0,0,0,0.08);
    }
    .avis-quote {
      font-family: var(--font-display);
      font-size: 4rem;
      color: var(--yellow);
      line-height: 0.5;
      margin-bottom: 20px;
      opacity: 0.7;
    }
    .avis-text {
      font-size: 0.85rem;
      font-weight: 400;
      color: var(--gray);
      line-height: 1.8;
      margin-bottom: 24px;
      font-style: italic;
    }
    .avis-stars {
      display: flex;
      gap: 3px;
      margin-bottom: 18px;
    }
    .avis-stars svg {
      width: 16px;
      height: 16px;
      fill: var(--yellow);
    }
    .avis-author {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .avis-avatar {
      width: 42px;
      height: 42px;
      border-radius: 50%;
      background: var(--red);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-display);
      font-size: 1rem;
      color: var(--white);
      flex-shrink: 0;
    }
    .avis-name {
      font-size: 0.82rem;
      font-weight: 700;
      color: var(--black);
    }
    .avis-date {
      font-size: 0.7rem;
      color: var(--text-muted);
      margin-top: 2px;
    }
    /* Google badge */
    .avis-verified {
      position: absolute;
      top: 20px;
      right: 20px;
      font-size: 0.65rem;
      font-weight: 600;
      color: var(--gray);
      letter-spacing: 0.08em;
      opacity: 0.6;
    }

    /* ════════════════════════════════════
       8. LOCALISATION
    ════════════════════════════════════ */
    #localisation {
      background: var(--black);
      padding: 110px 32px 100px;
    }
    .loc-inner {
      max-width: 1320px;
      margin: 0 auto;
    }
    .loc-header {
      text-align: center;
      margin-bottom: 64px;
    }
    .loc-header .section-label {
      justify-content: center;
    }
    .loc-header .section-label::before,
    .loc-header .section-label::after {
      content: '';
      width: 28px;
      height: 2px;
      background: var(--yellow);
    }
    .loc-title {
      font-family: var(--font-display);
      font-size: clamp(2.5rem, 4vw, 4.8rem);
      color: var(--cream);
      line-height: 0.95;
      letter-spacing: 0.02em;
      margin-bottom: 16px;
    }
    .loc-title span { color: var(--yellow); }
    .loc-sub {
      font-size: 1rem;
      color: var(--text-muted);
      max-width: 540px;
      margin: 0 auto;
    }

    .loc-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 22px;
    }
    .loc-card {
      position: relative;
      background: var(--black-deep);
      border: 1px solid rgba(243,236,34,0.1);
      border-radius: var(--radius-card);
      padding: 36px 30px 30px;
      overflow: hidden;
      transition: transform 0.4s var(--ease), border-color 0.3s ease, box-shadow 0.4s var(--ease);
      display: flex;
      flex-direction: column;
    }
    .loc-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, transparent 50%, rgba(173,0,4,0.10) 100%);
      opacity: 0;
      transition: opacity 0.4s var(--ease);
      pointer-events: none;
    }
    .loc-card:hover {
      transform: translateY(-6px);
      border-color: var(--yellow);
      box-shadow: 0 20px 50px rgba(173,0,4,0.22), 0 4px 12px rgba(0,0,0,0.3);
    }
    .loc-card:hover::before { opacity: 1; }

    .loc-card-num {
      font-family: var(--font-body);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      color: var(--red);
      margin-bottom: 10px;
      position: relative;
      z-index: 1;
    }
    .loc-card-name {
      font-family: var(--font-display);
      font-size: 2rem;
      letter-spacing: 0.06em;
      color: var(--cream);
      line-height: 1;
      margin-bottom: 18px;
      position: relative;
      z-index: 1;
    }
    .loc-card-addr {
      font-size: 0.92rem;
      font-weight: 500;
      color: var(--text-light);
      line-height: 1.55;
      margin-bottom: 18px;
      position: relative;
      z-index: 1;
    }
    .loc-card-meta {
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-bottom: 22px;
      padding-bottom: 22px;
      border-bottom: 1px solid rgba(245,240,232,0.1);
      position: relative;
      z-index: 1;
    }
    .loc-card-line {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 0.82rem;
      color: var(--text-muted);
    }
    .loc-card-line svg {
      width: 15px;
      height: 15px;
      stroke: var(--yellow);
      fill: none;
      stroke-width: 1.8;
      flex-shrink: 0;
    }
    .loc-card-ctas {
      display: flex;
      gap: 8px;
      margin-top: auto;
      position: relative;
      z-index: 1;
    }
    .loc-card-cta {
      flex: 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 11px 12px;
      border-radius: 50px;
      font-family: var(--font-body);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      background: var(--red);
      color: var(--white);
      transition: background 0.3s ease, transform 0.3s var(--ease), color 0.3s ease, border-color 0.3s ease;
      border: 1.5px solid var(--red);
    }
    .loc-card-cta:hover { background: var(--red-hover); border-color: var(--red-hover); transform: translateY(-2px); }
    .loc-card-cta-outline {
      background: transparent;
      color: var(--yellow);
      border: 1.5px solid rgba(243,236,34,0.35);
    }
    .loc-card-cta-outline:hover {
      background: var(--yellow);
      color: var(--black);
      border-color: var(--yellow);
    }

    @media (max-width: 1100px) {
      .loc-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 560px) {
      .loc-grid { grid-template-columns: 1fr; }
    }

    /* ════════════════════════════════════
       9. CTA BAND
    ════════════════════════════════════ */
    #cta-band {
      background: var(--red);
      padding: 72px 32px;
    }
    .cta-band-inner {
      max-width: 1320px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 32px;
      flex-wrap: wrap;
    }
    .cta-band-title {
      font-family: var(--font-display);
      font-size: clamp(2rem, 4vw, 4rem);
      color: var(--white);
      line-height: 0.95;
      letter-spacing: 0.02em;
    }
    .cta-band-title span { color: var(--yellow); }
    .cta-band-sub {
      font-size: 0.85rem;
      font-weight: 400;
      color: rgba(255,255,255,0.8);
      line-height: 1.7;
      margin-top: 10px;
    }
    .cta-band-right {
      display: flex;
      gap: 14px;
      align-items: center;
      flex-wrap: wrap;
    }

    /* ════════════════════════════════════
       10. FOOTER
    ════════════════════════════════════ */
    #footer {
      background: var(--black-deep);
      padding: 64px 32px 32px;
      border-top: 1px solid rgba(255,255,255,0.06);
    }
    .footer-inner {
      max-width: 1320px;
      margin: 0 auto;
    }
    .footer-top {
      display: grid;
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
      gap: 48px;
      padding-bottom: 48px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      margin-bottom: 32px;
    }
    .footer-brand-logo {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 16px;
    }
    .footer-brand-logo img {
      height: 46px;
      width: 46px;
      object-fit: contain;
      border-radius: 50%;
    }
    .footer-brand-name {
      font-family: var(--font-display);
      font-size: 1.5rem;
      color: var(--white);
    }
    .footer-desc {
      font-size: 0.8rem;
      color: var(--text-muted);
      line-height: 1.8;
      margin-bottom: 24px;
    }
    .footer-socials {
      display: flex;
      gap: 10px;
    }
    .social-link {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      border: 1px solid rgba(255,255,255,0.12);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text-muted);
      font-size: 0.8rem;
      transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
    }
    .social-link:hover {
      border-color: var(--yellow);
      color: var(--yellow);
      background: var(--yellow-dim);
    }
    .footer-col-title {
      font-family: var(--font-body);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--white);
      margin-bottom: 20px;
    }
    .footer-links {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .footer-links a {
      font-size: 0.82rem;
      color: var(--text-muted);
      transition: color 0.2s ease;
    }
    .footer-links a:hover { color: var(--white); }
    .footer-bottom {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
    }
    .footer-copy {
      font-size: 0.75rem;
      color: rgba(255,255,255,0.25);
    }
    .footer-legal {
      display: flex;
      gap: 24px;
    }
    .footer-legal a {
      font-size: 0.72rem;
      color: rgba(255,255,255,0.25);
      transition: color 0.2s ease;
    }
    .footer-legal a:hover { color: var(--text-muted); }

    /* ════════════════════════════════════
       RESPONSIVE
    ════════════════════════════════════ */
    @media (max-width: 1024px) {
      .pizza-grid { grid-template-columns: repeat(2, 1fr); }
      .story-inner { grid-template-columns: 1fr; gap: 48px; }
      .story-img-badge { right: 20px; }
      .loc-inner { grid-template-columns: 1fr; }
      .footer-top { grid-template-columns: 1fr 1fr; }
    }

    @media (max-width: 768px) {
      .nav-links, .nav-cta { display: none; }
      .nav-burger { display: flex; }
      .hero-delivery-badge { display: none; }
      .hero-title { font-size: clamp(3.2rem, 11vw, 6rem); }
      .trust-inner { flex-wrap: wrap; gap: 0; }
      .trust-item { min-width: 50%; padding: 12px 0; }
      .trust-item:nth-child(n+3) { border-top: 1px solid rgba(243,236,34,0.25); }
      .trust-item:nth-child(odd) { border-left: none; }
      .offres-grid { grid-template-columns: 1fr; }
      .offre-card { flex-direction: column; min-height: auto; }
      .offre-img { width: 100%; height: 200px; }
      .avis-grid { grid-template-columns: 1fr; }
      .menu-header { flex-direction: column; align-items: flex-start; }
      .cta-band-inner { justify-content: center; text-align: center; }
      .cta-band-right { justify-content: center; }
      .footer-top { grid-template-columns: 1fr; gap: 32px; }
      .footer-bottom { flex-direction: column; text-align: center; }
      .footer-legal { justify-content: center; }
    }

    @media (max-width: 480px) {
      .pizza-grid { grid-template-columns: 1fr; }
      .hero-ctas { flex-direction: column; align-items: flex-start; }
      .btn { width: 100%; justify-content: center; }
      .loc-ctas { flex-direction: column; }
      .loc-ctas .btn { width: 100%; justify-content: center; }
      #menu, #offres, #story, #avis, #localisation { padding: 72px 20px; }
    }

    /* Focus visible */
    :focus-visible {
      outline: 2px solid var(--yellow);
      outline-offset: 3px;
      border-radius: 4px;
    }
  </style>
</head>
<body>

  <!-- ══ NAVIGATION ══ -->
  <nav id="main-nav" role="navigation" aria-label="Navigation principale">
    <div class="nav-inner">
      <a href="#" class="nav-logo" aria-label="C Pizza — Accueil">
        <img src="brand_assets/logo-new.jpeg" alt="Logo C Pizza" width="46" height="46">
        <div>
          <div class="nav-logo-text">C PIZZA</div>
          <div class="nav-logo-sub">Maképé Saint Tropez</div>
        </div>
      </a>

      <ul class="nav-links" role="list">
        <li><a href="menu.html">Menu</a></li>
        <li><a href="offres.html">Offres</a></li>
        <li><a href="story.html">Notre histoire</a></li>
        <li><a href="#localisation">Nous trouver</a></li>
      </ul>

      <a href="tel:+237600000000" class="btn btn-red nav-cta" aria-label="Commander par téléphone">
        Commander →
      </a>

      <button class="nav-burger" id="burger-btn" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="mobile-menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- Mobile drawer -->
  <div class="mobile-menu" id="mobile-menu" role="dialog" aria-label="Menu mobile">
    <a href="menu.html" class="mobile-link">Menu</a>
    <a href="offres.html" class="mobile-link">Offres</a>
    <a href="story.html" class="mobile-link">Notre histoire</a>
    <a href="#localisation" class="mobile-link">Nous trouver</a>
    <a href="tel:+237600000000" class="btn btn-red" style="width:100%;justify-content:center;border-radius:50px;margin-top:16px;">
      Commander maintenant
    </a>
  </div>

  <!-- ══ HERO ══ -->
  <section id="hero" aria-label="Bannière principale">
    <div class="hero-bg" aria-hidden="true">
      <img src="https://placehold.co/1600x900/1a0505/2a0505?text=." alt="" role="presentation">
    </div>
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="hero-accent-bar" aria-hidden="true"></div>

    <div class="hero-content">
      <div class="hero-badge fade-up">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
        Maképé Saint Tropez · Douala
      </div>

      <h1 class="hero-title fade-up delay-1">
        LA PIZZA QUI<br>
        <span>RÉVEILLE</span><br>
        DOUALA
      </h1>

      <p class="hero-sub fade-up delay-2">
        <strong>Four à 450°C</strong> · Pâte fermentée 72h · Ingrédients frais sélectionnés.<br>
        Livraison en 30 minutes à Maképé et ses environs.
      </p>

      <div class="hero-ctas fade-up delay-3">
        <a href="tel:+237600000000" class="btn btn-red">
